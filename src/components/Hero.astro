---

---

<section class="hero">
  <div class="hero-inner">
    <p class="label">URL Trust Scanner</p>

    <h1>Is this website safe to trust?</h1>

    <p class="subtext">
      Paste any URL and get an instant trust score. No account needed.
    </p>

    <form class="scan-form" id="scan-form">
      <div class="input-wrap">
        <svg
          class="input-icon"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path
            d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <input
          type="text"
          name="url"
          placeholder="https://example.com"
          required
          autocomplete="off"
          spellcheck="false"
          aria-label="URL to scan"
        />
      </div>
      <button type="submit">Scan URL</button>
    </form>

    <p id="url-error" class="url-error" aria-live="polite"></p>

    <p class="privacy-note">
      🔒 We do not store any URLs you submit. ·
      <a href="/privacy">Privacy Policy</a>
    </p>
  </div>
</section>

<script>
  const form = document.getElementById('scan-form') as HTMLFormElement;
  const errorEl = document.getElementById('url-error') as HTMLParagraphElement;
  const input = form.querySelector('input[name="url"]') as HTMLInputElement;

  function isValidUrl(url: string): boolean {
    try {
      const { hostname } = new URL(url);
      return (
        /^[^\s]+\.[a-z]{2,}$/i.test(hostname) ||
        /^\d{1,3}(\.\d{1,3}){3}$/.test(hostname)
      );
    } catch {
      return false;
    }
  }

  function showValidationError() {
    errorEl.textContent = 'Please enter a valid URL, e.g. https://example.com';
    input.setAttribute('aria-invalid', 'true');
  }

  function clearValidationError() {
    errorEl.textContent = '';
    input.removeAttribute('aria-invalid');
  }

  input.addEventListener('input', clearValidationError);

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    let url = input.value.trim();
    if (!url) return;
    if (!url.startsWith('http://') && !url.startsWith('https://')) {
      url = 'https://' + url;
    }
    if (!isValidUrl(url)) {
      showValidationError();
      return;
    }
    clearValidationError();
    document.dispatchEvent(new CustomEvent('scan:start', { detail: { url } }));
  });
</script>

<style>
  .hero {
    padding: var(--space-16) var(--space-8);
    text-align: center;
  }

  .hero-inner {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  h1 {
    font-size: var(--text-3xl);
    color: var(--color-text);
    line-height: 1.2;
  }

  .subtext {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-top: calc(var(--space-6) * -0.5);
  }

  .scan-form {
    display: flex;
    gap: var(--space-2);
    align-items: stretch;
  }

  .input-wrap {
    position: relative;
    flex: 1;
  }

  .input-icon {
    position: absolute;
    left: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  input {
    width: 100%;
    height: 100%;
    padding: var(--space-2) var(--space-3) var(--space-2) 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-size: var(--text-base);
    transition: border-color var(--transition-fast);
  }

  input::placeholder {
    color: var(--color-text-muted);
  }

  input:focus {
    outline: none;
    border-color: var(--color-text-secondary);
  }

  button[type="submit"] {
    padding: var(--space-2) var(--space-6);
    background: var(--color-text);
    color: var(--color-bg);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: 600;
    white-space: nowrap;
    transition: opacity var(--transition-fast);
  }

  button[type="submit"]:hover {
    opacity: 0.85;
  }

  .url-error {
    font-size: var(--text-xs);
    color: var(--color-signal-red);
    min-height: 1em;
    margin-top: calc(var(--space-6) * -0.5);
  }

  .privacy-note {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .privacy-note a {
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .privacy-note a:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .scan-form {
      flex-direction: column;
    }

    input {
      padding: var(--space-3) var(--space-3) var(--space-3) 2.5rem;
    }

    button[type="submit"] {
      width: 100%;
      padding: var(--space-3);
    }
  }
</style>
